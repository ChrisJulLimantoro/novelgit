# Copy to .env.local and fill in values. Never commit .env.local.

# GitHub PAT: contents read/write + metadata read for the content repository
GITHUB_TOKEN=

# Content repository in owner/repo form (e.g. myuser/novelgit-content)
GITHUB_REPO=

# Single-user passphrase; users enter this on the home page (after the hero) to unlock /library and /edit
AUTH_SECRET=
