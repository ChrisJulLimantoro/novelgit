# Copy to .env.local and fill in values. Never commit .env.local.

# Public site URL (no trailing slash). Used for canonical URLs, Open Graph, sitemap, and JSON-LD.
# On Vercel, set this to your production domain (e.g. https://novelgit.vercel.app). Falls back to VERCEL_URL if unset.
NEXT_PUBLIC_SITE_URL=

# GitHub PAT: contents read/write + metadata read for the content repository
GITHUB_TOKEN=

# Content repository — must be exactly owner/repo (validated at startup). Example: myuser/novelgit-content
GITHUB_REPO=

# Single-user passphrase (users type this on the home page after the hero).
# The app stores an opaque session cookie derived via HMAC; it does not store this string in the cookie value.
AUTH_SECRET=

# AI — LLM (Groq). Required for scaffold-lore + chat completions.
GROQ_API_KEY=

# Lore embeddings (Voyage HTTPS).
VOYAGE_API_KEY=

# Manuscript embeddings (OpenRouter — nvidia/llama-nemotron-embed-vl-1b-v2:free).
# Free tier: 20 req/min, 200 req/day. Also used for HyDE query expansion in chat.
OPENROUTER_API_KEY=

# Chapter distillation + Global Bible generation (Google Gemini REST).
# Free tier: gemini-2.0-flash 1,500 req/day; gemini-1.5-flash 1,500 req/day, 1M TPM.
# If absent, reindex skips distillation and no global-summary.md is generated.
GEMINI_API_KEY=
